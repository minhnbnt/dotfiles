{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 2, // Gaps between modules
    // Choose the order of the modules
    "modules-left": [
        "wlr/workspaces",
        "hyprland/window",
        "hyprland/submap"
    ],
    "modules-center": [],
    "modules-right": [
        "network",
        "custom/cpu",
        //"cpu",
        "custom/temp",
        "memory",
        //"custom/ram",
        "custom/battery",
        "backlight",
        "custom/volume",
        "custom/mic",
        "clock",
        "custom/ibus",
        "tray"
    ],
    // Modules configuration
    "wlr/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}<sup> {name}</sup>",
        "sort-by-number": true,
        "format-active": "{icon}",
        "on-click": "activate",
        "active-only": false,
        "format-icons": {
            "1": "пД†",
            "2": "пЙ®",
            "3": "пБД",
            "4": "пБЉ",
            "5": "пАИ",
            "6": "пДЫ",
            "7": "пАљ",
            "urgent": "пБ™",
            "focused": "пЖТ",
            "default": "пДС"
        }
    },
    "clock": {
        "interval": 1,
        "format": "пАЧ {:%H:%M:%S}",
        "format-alt": "пБ≥ {:%a %b %d, %G}",
        "tooltip": false
    },
    "hyprland/submap": {
        "format": "вЬМпЄП {}",
        "max-length": 8,
        "tooltip": false
    },
    "hyprland/window": {
        "format": "пЛР {}",
        // "interval": 1,
        "separate-outputs": true,
        "tooltip": false
    },
    "custom/ram": {
        "exec": "sh ~/.config/i3/ram.sh",
        "interval": 10,
        "format": "пЗА {}"
    },
    "custom/cpu": {
        //"return-type": "json",
        //"format": "пЛЫ {usage}%",
        //"format-alt": "{icon} {ferq} {temp}",
        "exec": "~/.config/waybar/cpu",
        //"exec": "sh ~/.config/waybar/cpu.sh",
        "tooltip": false,
        "interval": 10
    },
    "cpu": {
        "interval": 10,
        "format": "пЛЫ {avg_frequency}GHz {usage}%",
        "format-alt": "пЛЫ {usage}%",
        "tooltip": false
    },
    "network": {
        "interface": "wlp2s0",
        "format": "",
        "interval": 10,
        "format-alt": "пГШ {bandwidthUpBits}  пГЧ {bandwidthDownBits}",
        "format-wifi": "пЗЂ {essid} ({signalStrength}%)",
        "format-ethernet": "пЫњ {ipaddr}/{cidr}",
        "tooltip": false,
        "format-disconnected": "Disconnected"
    },
    "custom/temp": {
        "exec": "~/.config/waybar/cpu -t thermal_zone1",
        "interval": 5,
        "format": "пЛЙ {}"
    },
    "custom/volume": {
        "exec": "sh ~/.config/i3/volume.sh",
        "on-click-right": "pamixer -i 5",
        "on-click-middle": "pamixer -t",
        "on-click": "pamixer -d 5",
        "tooltip": false,
        "interval": 1
    },
    "custom/mic": {
        "on-click-middle": "amixer -q sset Capture toggle",
        "on-click-right": "amixer -q sset Capture 5%+",
        "on-click": "amixer -q sset Capture 5%-",
        "exec": "~/.config/waybar/mic",
        "tooltip": false,
        "interval": 1
    },
    "custom/battery": {
        "exec": "python3 ~/.config/i3/battery.py",
        "tooltip": false,
        "interval": 10
    },
    "memory": {
        "interval": 10,
        "format": "пЗА {percentage}%",
        "format-alt": "пЗА {used:0.1f}G/{total:0.1f}G",
        "state": {
            "alert": 80,
            "warning": 60,
            "normal": 40,
            "good": 20,
            "best": 0
        },
        "tooltip": false
    },
    "backlight": {
        "interval": 1,
        // "device": "acpi_video1",
        "format": "<span>{icon}&#xFE0E;</span><sup> </sup>{percent}%",
        "tooltip": false,
        //"format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
        "format-icons": [
            "рЯМС",
            "рЯМТ",
            "рЯМУ",
            "рЯМФ",
            "рЯМХ"
        ],
        "on-click": "light -U 10",
        "on-click-right": "light -A 10"
    },
    "custom/ibus": {
        "on-click": "~/.config/waybar/im e",
        "on-click-right": "~/.config/waybar/im l",
        "tooltip": false,
        "exec": "~/.config/waybar/im nocolor",
        "interval": 1
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    }
}
